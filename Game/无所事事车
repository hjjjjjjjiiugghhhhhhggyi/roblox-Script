local CartTab = Window:AddTab("Cart Settings", "truck", "马车控制")
local CartGroup = CartTab:AddLeftGroupbox("马车操控")

local function getCart()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.SeatPart then
        return hum.SeatPart.Parent
    end
    return nil
end

CartGroup:AddToggle("PanicStop", {
    Text = "紧急制动",
    Default = false,
    Tooltip = "开启后锚定马车所有部件",
    Callback = function(state)
        local cart = getCart()
        if not cart then
            Library:Notify({ Title = "提示", Description = "没有坐在马车上", Time = 2 })
            return
        end
        for _, part in pairs(cart:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if state then
                    part.AssemblyLinearVelocity = Vector3.zero
                    part.AssemblyAngularVelocity = Vector3.zero
                end
            end
        end
    end
})

local function teleportCart(cframe)
    local cart = getCart()
    if not cart or not cart.PrimaryPart then
        Library:Notify({ Title = "错误", Description = "找不到马车的主部件", Time = 3 })
        return
    end
    cart:SetPrimaryPartCFrame(cframe)
    cart.PrimaryPart.AssemblyLinearVelocity = Vector3.zero
    cart.PrimaryPart.AssemblyAngularVelocity = Vector3.zero
    Library:Notify({ Title = "传送马车", Description = "马车已传送到检查点", Time = 2 })
end

